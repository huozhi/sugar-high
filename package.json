{
  "name": "sugar-high-monorepo",
  "private": true,
  "description": "Monorepo for sugar-high and remark-sugar-high packages",
  "type": "module",
  "scripts": {
    "build": "pnpm -r run build",
    "test": "pnpm -r run test",
    "dev": "pnpm -r run dev",
    "clean": "pnpm -r run clean",
    "site": "pnpm --filter docs dev",
    "docs:build": "pnpm build && pnpm --filter docs build",
    "release-video:studio": "pnpm --filter release-video dev",
    "release-video:render": "pnpm --filter release-video render"
  },
  "packageManager": "pnpm@9.12.2",
  "license": "MIT",
  "author": "huozhi",
  "devDependencies": {
    "next": "^16.2.0"
  },
  "pnpm": {
    "overrides": {
      "sugar-high": "workspace:*"
    },
    "packageExtensions": {
      "codice@*": {
        "dependencies": {
          "sugar-high": "workspace:*"
        }
      }
    }
  }
}
